# Supabase
# Preferred: set SUPABASE_ID and SUPABASE_API_KEY. The app derives
# NEXT_PUBLIC_SUPABASE_URL and NEXT_PUBLIC_SUPABASE_ANON_KEY at build time.
SUPABASE_ID=
SUPABASE_API_KEY=

# Optional server-side Supabase secret. Not exposed to the client bundle.
SUPABASE_SECRET=

# Optional legacy fallback names.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Auth.js / NextAuth
AUTH_SECRET=
AUTH_URL=
NEXTAUTH_SECRET=
NEXTAUTH_URL=

# Google OAuth provider
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Gmail SMTP for order/application emails
GMAIL_USERNAME=
GMAIL_PASSWORD=
